# ── API Keys ──
VT_API_KEY=your_virustotal_api_key_here
ABUSEIPDB_API_KEY=your_abuseipdb_key_here
OTX_API_KEY=your_otx_key_here

# ── Rate Limits (seconds between requests) ──
VT_DELAY=15.0
ABUSEIPDB_DELAY=1.0
OTX_DELAY=0.5

# ── Redis ──
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=86400

# ── App ──
CONCURRENCY=5